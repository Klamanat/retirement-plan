// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  name               String?
  password           String
  createdAt          DateTime            @default(now())
  budgets            Budget[]
  pins               MapPin[]
  trips              Trip[]
  retirementSetting  RetirementSetting?
}

model RetirementSetting {
  id              String   @id @default(cuid())
  userId          String   @unique
  currentAge      Int      @default(30)
  retirementAge   Int      @default(60)
  lifeExpectancy  Int      @default(85)
  currentSavings  Float    @default(0)
  expectedReturn  Float    @default(5)
  inflationRate   Float    @default(3)
  monthlyExpense  Float?
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id])
}

model Budget {
  id        String   @id @default(cuid())
  userId    String
  year      Int
  month     Int
  category  String
  amount    Float
  note      String?
  type      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model MapPin {
  id        String   @id @default(cuid())
  userId    String
  name      String
  lat       Float
  lng       Float
  note      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Trip {
  id          String    @id @default(cuid())
  userId      String
  name        String
  destination String
  startDate   DateTime?
  endDate     DateTime?
  budget      Float?
  spent       Float     @default(0)
  status      String    @default("planning")
  note        String?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])
}
